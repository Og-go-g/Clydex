# AI Provider (one required)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Portfolio — multi-chain balances (https://moralis.io)
MORALIS_API_KEY=

# Base RPC (comma-separated, tried in order with auto-fallback)
BASE_RPC_URLS=

# DEX aggregators (comma-separated, tried in order, auto-fallback on 429)
OPENOCEAN_URLS=
PARASWAP_URLS=

# Token prices (comma-separated, tried in order, auto-fallback on 429)
DEXSCREENER_URLS=

# Yields/APY (comma-separated, tried in order, auto-fallback on 429)
DEFILLAMA_URLS=

# GeckoTerminal — OHLCV chart data (comma-separated, auto-fallback on 429)
GECKOTERMINAL_URLS=

# SIWE auth — session encryption secret (min 32 chars, MUST change in production)
SIWE_SECRET=

# Database — Neon PostgreSQL (https://neon.tech)
DATABASE_URL=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
