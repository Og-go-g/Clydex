# AI Provider (one required)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Solana RPC (server-side only — never exposed to browser)
# Free: https://api.mainnet-beta.solana.com (low limits, ~10 req/s)
# Recommended: Helius free tier (50 req/s) — sign up at https://helius.dev
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# N1 / 01 Exchange
N1_WEB_SERVER_URL=https://zo-mainnet.n1.xyz
N1_WS_URL=wss://zo-mainnet.n1.xyz/ws
N1_APP_ID=
N1_NETWORK=mainnet

# Session encryption (min 32 chars, MUST change in production)
SESSION_SECRET=

# Database — Neon PostgreSQL
DATABASE_URL=

# Rate limiting — Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job authentication (used by Vercel Cron for /api/cron/collect-prices)
CRON_SECRET=

# Monitoring — Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
