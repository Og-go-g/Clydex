generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
//  User — one row per Solana wallet address
// ---------------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  address   String   @unique            // base58 Solana public key
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  ChatSession[]
  trades    Trade[]
  alerts    Alert[]

  @@map("users")
}

// ---------------------------------------------------------------------------
//  ChatSession — a conversation thread
// ---------------------------------------------------------------------------
model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

// ---------------------------------------------------------------------------
//  ChatMessage — individual message in a session
// ---------------------------------------------------------------------------
model ChatMessage {
  id        String   @id @default(cuid())
  role      String                       // "user" | "assistant"
  content   String   @default("")        // plain text content
  parts     Json?                        // AI SDK parts array (tool results etc.)
  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ---------------------------------------------------------------------------
//  Trade — executed perpetual futures trade record
// ---------------------------------------------------------------------------
model Trade {
  id         String   @id @default(cuid())
  marketId   Int                          // N1 market ID (0=BTC, 1=ETH, etc.)
  symbol     String                       // "BTC-PERP"
  side       String                       // "Long" | "Short"
  size       Decimal  @db.Decimal(30, 18) // base asset units
  price      Decimal  @db.Decimal(30, 18) // entry/exit price
  leverage   Decimal  @db.Decimal(10, 4)  // leverage used
  orderId    String?                      // N1 order ID
  actionId   String?                      // N1 action ID
  orderType  String   @default("market")  // "market" | "limit" | "stop_loss" | "take_profit"
  status     String   @default("pending") // "pending" | "filled" | "cancelled" | "failed"
  pnl        Decimal? @db.Decimal(30, 18) // realized PnL in USDC
  fee        Decimal? @db.Decimal(30, 18) // trading fee in USDC
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
  @@map("trades")
}

// ---------------------------------------------------------------------------
//  Alert — liquidation and risk alerts
// ---------------------------------------------------------------------------
model Alert {
  id          String   @id @default(cuid())
  type        String                       // "liquidation_warning" | "liquidation_critical" | "liquidation_emergency"
  marketId    Int?                          // specific market, or null for account-level
  symbol      String?                       // "BTC-PERP" etc.
  marginRatio Decimal  @db.Decimal(10, 6)    // margin ratio at time of alert
  message     String                        // human-readable alert text
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("alerts")
}

// ---------------------------------------------------------------------------
//  PriceHistory — hourly mark prices from 01 Exchange for chart data
// ---------------------------------------------------------------------------
model PriceHistory {
  id       Int      @id @default(autoincrement())
  marketId Int                          // N1 market ID
  time     DateTime                     // 15-min interval timestamp
  price    Decimal  @db.Decimal(30, 18)  // mark price in USD

  @@unique([marketId, time])
  @@index([marketId, time])
  @@map("price_history")
}

// ---------------------------------------------------------------------------
//  RateLimitBucket — fixed-window rate-limit counter, used as a Postgres
//  fallback when Upstash Redis is unreachable or its monthly free-tier
//  quota is exhausted. Keyed by "<tier-prefix>:<wallet-or-ip>".
//
//  Atomic increment + window-rollover via a single INSERT ... ON CONFLICT
//  ... DO UPDATE with a CASE expression — see lib/ratelimit.ts pgRateLimit.
// ---------------------------------------------------------------------------
model RateLimitBucket {
  key         String   @id
  count       Int
  windowStart DateTime @map("window_start") @db.Timestamptz(3)

  @@index([windowStart], map: "idx_rl_bucket_window")
  @@map("rate_limit_buckets")
}

// ---------------------------------------------------------------------------
//  Nonce — one-time SIWS sign-in nonce. Atomic single-use guarantee via
//  DELETE ... WHERE expires_at > NOW() RETURNING — see lib/auth/nonce-store.ts.
// ---------------------------------------------------------------------------
model Nonce {
  value     String   @id
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)

  @@index([expiresAt], map: "idx_nonce_expires")
  @@map("nonces")
}

// ---------------------------------------------------------------------------
//  IdempotencyKey — short-lived store of "first response wins" results for
//  POST /api/order. Prevents network retries from double-executing orders.
//  TTL 5 minutes, atomic ON CONFLICT DO NOTHING + GET semantics.
// ---------------------------------------------------------------------------
model IdempotencyKey {
  key       String   @id
  result    Json
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)

  @@index([expiresAt], map: "idx_idem_expires")
  @@map("idempotency_keys")
}

// ---------------------------------------------------------------------------
//  OrderPreview — AI-generated order preview, single-use, owner-scoped.
//  TTL 5 minutes, consume = atomic DELETE ... WHERE id+user_id+expires_at>NOW
//  RETURNING — ownership and TTL enforced in one statement so a different
//  user can't burn someone else's preview.
// ---------------------------------------------------------------------------
model OrderPreview {
  id        String   @id
  userId    String   @map("user_id")
  payload   Json
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)

  @@index([expiresAt], map: "idx_preview_expires")
  @@map("order_previews")
}
