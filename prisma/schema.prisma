generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
//  User — one row per Solana wallet address
// ---------------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  address   String   @unique            // base58 Solana public key
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  ChatSession[]
  trades    Trade[]
  alerts    Alert[]

  @@map("users")
}

// ---------------------------------------------------------------------------
//  ChatSession — a conversation thread
// ---------------------------------------------------------------------------
model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

// ---------------------------------------------------------------------------
//  ChatMessage — individual message in a session
// ---------------------------------------------------------------------------
model ChatMessage {
  id        String   @id @default(cuid())
  role      String                       // "user" | "assistant"
  content   String   @default("")        // plain text content
  parts     Json?                        // AI SDK parts array (tool results etc.)
  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ---------------------------------------------------------------------------
//  Trade — executed perpetual futures trade record
// ---------------------------------------------------------------------------
model Trade {
  id         String   @id @default(cuid())
  marketId   Int                          // N1 market ID (0=BTC, 1=ETH, etc.)
  symbol     String                       // "BTC-PERP"
  side       String                       // "Long" | "Short"
  size       Decimal  @db.Decimal(30, 18) // base asset units
  price      Decimal  @db.Decimal(30, 18) // entry/exit price
  leverage   Decimal  @db.Decimal(10, 4)  // leverage used
  orderId    String?                      // N1 order ID
  actionId   String?                      // N1 action ID
  orderType  String   @default("market")  // "market" | "limit" | "stop_loss" | "take_profit"
  status     String   @default("pending") // "pending" | "filled" | "cancelled" | "failed"
  pnl        Decimal? @db.Decimal(30, 18) // realized PnL in USDC
  fee        Decimal? @db.Decimal(30, 18) // trading fee in USDC
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
  @@map("trades")
}

// ---------------------------------------------------------------------------
//  Alert — liquidation and risk alerts
// ---------------------------------------------------------------------------
model Alert {
  id          String   @id @default(cuid())
  type        String                       // "liquidation_warning" | "liquidation_critical" | "liquidation_emergency"
  marketId    Int?                          // specific market, or null for account-level
  symbol      String?                       // "BTC-PERP" etc.
  marginRatio Decimal  @db.Decimal(10, 6)    // margin ratio at time of alert
  message     String                        // human-readable alert text
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("alerts")
}

// ---------------------------------------------------------------------------
//  PriceHistory — hourly mark prices from 01 Exchange for chart data
// ---------------------------------------------------------------------------
model PriceHistory {
  id       Int      @id @default(autoincrement())
  marketId Int                          // N1 market ID
  time     DateTime                     // 15-min interval timestamp
  price    Decimal  @db.Decimal(30, 18)  // mark price in USD

  @@unique([marketId, time])
  @@index([marketId, time])
  @@map("price_history")
}
